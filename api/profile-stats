export default async function handler(req, res){

  const SUPABASE_URL = process.env.SUPABASE_URL
  const KEY = process.env.SUPABASE_SERVICE_KEY

  const { wallet } = req.query

  if(!wallet) return res.json({})

  try{

    // votes
    const votesRes = await fetch(
      `${SUPABASE_URL}/rest/v1/votes?wallet=eq.${wallet}&select=*`,
      {
        headers:{
          apikey: KEY,
          Authorization:`Bearer ${KEY}`
        }
      }
    )
    const votes = await votesRes.json()

    // projects voted on (unique)
    const projectIds = [...new Set(votes.map(v => v.project_id))]

    // manifesto
    const manRes = await fetch(
      `${SUPABASE_URL}/rest/v1/manifesto?wallet=eq.${wallet}&select=*`,
      {
        headers:{
          apikey: KEY,
          Authorization:`Bearer ${KEY}`
        }
      }
    )
    const manifesto = await manRes.json()

    return res.json({
      totalVotes: votes.reduce((s,v)=>s+v.amount,0),
      projectsVoted: projectIds,
      hasSigned: manifesto.length > 0
    })

  }catch(err){
    console.log("profile stats error", err)
    return res.status(500).json({})
  }
}